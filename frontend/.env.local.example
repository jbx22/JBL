# JBL BIZ LAW — Environment Variables for Vercel Deployment
#
# Run `vercel env add <KEY> production` for each variable,
# or paste them all into Vercel Dashboard → Settings → Environment Variables.

# ---- REQUIRED ----
# Supabase Postgres connection string
# Use Supabase Project Settings > Database > Connection string.
# The transaction pooler URL is recommended for serverless deployments.
DATABASE_URL=postgresql://postgres.your-project-ref:password@aws-0-region.pooler.supabase.com:6543/postgres?sslmode=require

# Supabase API keys used by Mike-compatible auth/storage helpers
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SECRET_KEY=your-supabase-service-role-key
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-supabase-anon-or-publishable-key

# ---- REQUIRED ----
# Auth.js secret — generate with: npx auth secret
AUTH_SECRET=your-generated-auth-secret-here

# ---- REQUIRED ----
# Auth.js canonical URL (Vercel deployment URL)
AUTH_URL=https://your-app.vercel.app

# ---- REQUIRED (for file uploads) ----
# Cloudflare R2
R2_ACCOUNT_ID=your-r2-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=your-r2-bucket-name
R2_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com

# ---- OPTIONAL ----
# AI provider API keys — users can also set their own in-app
# DEEPSEEK_API_KEY=sk-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...
# CLAUDE_API_KEY=sk-ant-...

# Moyasar payment gateway
# MOYASAR_SECRET_KEY=sk_test_or_live_...

# Rate limiting (defaults shown)
# RATE_LIMIT_GENERAL_MAX=300
# RATE_LIMIT_CHAT_MAX=30

# ---- FRONTEND ----
# Points to Next.js API routes (leave as /api for production)
NEXT_PUBLIC_API_BASE_URL=/api
