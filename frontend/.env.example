# =============================================================================
# JBL BIZ LAW — Environment Variables
# =============================================================================

# --- Database (Neon Postgres) ---
DATABASE_URL="postgresql://user:password@ep-example.us-east-2.aws.neon.tech/jblbizlaw?sslmode=require"

# --- Auth.js (NextAuth v5) ---
AUTH_SECRET="generate-with: openssl rand -base64 32"
AUTH_URL="http://localhost:3000"

# --- Cloudflare R2 Storage ---
R2_ACCESS_KEY_ID="your-r2-access-key"
R2_SECRET_ACCESS_KEY="your-r2-secret-key"
R2_BUCKET_NAME="jbl-biz-law-storage"
R2_ENDPOINT="https://your-account.r2.cloudflarestorage.com"
R2_PUBLIC_URL="https://your-bucket.example.com"

# --- AI Providers (Optional - users can set their own keys) ---
OPENAI_API_KEY="sk-..."
DEEPSEEK_API_KEY="sk-..."
GEMINI_API_KEY="..."
ANTHROPIC_API_KEY="sk-ant-..."

# --- Payments (Moyasar) ---
# Secret key stays server-side. Get it from https://dashboard.moyasar.com/
MOYASAR_SECRET_KEY="sk_test_or_live_..."

# --- Next.js ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_BASE_URL="/api"

# --- Deployment (Vercel) ---
# Set these in Vercel dashboard, not here
# NEXT_PUBLIC_VERCEL_URL will be auto-set by Vercel
