# =============================================================================
# JBL BIZ LAW — Environment Variables
# =============================================================================

# --- Database (Supabase Postgres) ---
# Use Supabase Project Settings > Database > Connection string.
# The transaction pooler URL is recommended for serverless deployments.
DATABASE_URL="postgresql://postgres.your-project-ref:password@aws-0-region.pooler.supabase.com:6543/postgres?sslmode=require"
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_SECRET_KEY="your-supabase-service-role-key"
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY="your-supabase-anon-or-publishable-key"

# --- Auth.js (NextAuth v5) ---
AUTH_SECRET="generate-with: openssl rand -base64 32"
AUTH_URL="http://localhost:3000"

# --- Cloudflare R2 Storage ---
R2_ACCESS_KEY_ID="your-r2-access-key"
R2_SECRET_ACCESS_KEY="your-r2-secret-key"
R2_BUCKET_NAME="jbl-biz-law-storage"
R2_ENDPOINT="https://your-account.r2.cloudflarestorage.com"
R2_PUBLIC_URL="https://your-bucket.example.com"

# --- AI Providers (Optional - users can set their own keys) ---
OPENAI_API_KEY="sk-..."
GEMINI_API_KEY="..."
ANTHROPIC_API_KEY="sk-ant-..."

# --- Next.js ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_BASE_URL="/api"

# --- Deployment (Vercel) ---
# Set these in Vercel dashboard, not here
# NEXT_PUBLIC_VERCEL_URL will be auto-set by Vercel
